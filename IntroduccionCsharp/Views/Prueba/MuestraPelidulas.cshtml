@model List<IntroduccionCsharp.Models.Pelicula>

@{
    ViewBag.Title = "MuestraPelidulas";
}

<h2>MuestraPelidulas</h2>
<div class="container">
    <div class="row">
        <table>
            <thead>
                <th>Tirulo</th>
                <th>Duracion</th>
                <th>Pais</th>
                <th>Lanzamiento</th>
            </thead>
            <tbody>
                @foreach(var pelicula in Model)
            {
                <tr>
                    <td>@pelicula.Titulo</td>
                    <td>@pelicula.Duracion</td>
                    <td>@pelicula.Pais</td>
                    <td>@pelicula.Publicacion.ToString("dd/mm/yyyy")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>