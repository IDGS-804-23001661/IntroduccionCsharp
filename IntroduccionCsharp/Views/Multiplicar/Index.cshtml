@model IntroduccionCsharp.Models.MultiplicacionSuma

@{
    ViewBag.Title = "Index";
}

<h2>Multiplicador</h2>

<div class="container">
    <div class="row">
        <div class="col-lg-6">

            <form action="/Multiplicar/Index" method="post">

                <label for="Num1">Numero 1: </label>
                <input type="text" name="Num1" value="@Model.Num1" />
                <br />

                <label for="Num2">Numero 2: </label>
                <input type="text" name="Num2" value="@Model.Num2" />
                <br />

                <input type="submit" value="Calcular" />

            </form>

        </div>

        <div class="col-lg-10">
            <br />

            <h3>
                @for (int i = 0; i < Model.Num2; i++)
                {
                    @Model.Num1

                    if (i < Model.Num2 - 1)
                    {
                        @:+
                    }
                }

                = @Model.Res
            </h3>

        </div>
    </div>
</div>